[Unit]
Description=Polybot Onchain-Memecoin (Der Onchain) — Paper Trading
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/crypto-trading-bot
ExecStart=/root/crypto-trading-bot/bot-env/bin/python3 -m polybot.main_memecoin
Restart=always
RestartSec=30
Environment=PYTHONUNBUFFERED=1
Environment=CHAIN_BUDGET=100
Environment=CHAIN_INTERVAL_SEC=300
Environment=CHAIN_ENTRY_CHANGE_PCT=8.0
Environment=CHAIN_ENTRY_MAX_CHANGE_PCT=35.0
Environment=CHAIN_MAX_H6_CHANGE_PCT=100.0
Environment=CHAIN_MIN_LIQUIDITY_USD=50000
Environment=CHAIN_MIN_LIQUIDITY_DYNAMIC_USD=100000
Environment=CHAIN_MIN_VOLUME_USD=100000
Environment=CHAIN_MIN_VOLUME_DYNAMIC_USD=500000
Environment=CHAIN_MIN_BUY_SELL_RATIO=1.2
Environment=CHAIN_MIN_H1_TXNS=50
Environment=CHAIN_DYNAMIC_ENABLED=true
Environment=CHAIN_MAX_DYNAMIC_TOKENS=15
Environment=CHAIN_MAX_DYNAMIC_POSITIONS=2
Environment=CHAIN_MIN_PAIR_AGE_H=24
Environment=CHAIN_POSITION_EUR=8
Environment=CHAIN_MAX_OPEN_POSITIONS=3
Environment=CHAIN_TAKE_PROFIT_PCT=15
Environment=CHAIN_TRAILING_STOP_PCT=12
Environment=CHAIN_TRAIL_FLOOR_PCT=5
Environment=CHAIN_STOP_LOSS_PCT=10
Environment=CHAIN_MAX_HOLD_H=24
Environment=CHAIN_COOLDOWN_H=4
Environment=CHAIN_COOLDOWN_AFTER_STOP_H=24
Environment=CHAIN_SLIPPAGE_PCT=1.5
Environment=CHAIN_DEX_FEE_PCT=1.0
Environment=CHAIN_PAPER_MODE=true

[Install]
WantedBy=multi-user.target
