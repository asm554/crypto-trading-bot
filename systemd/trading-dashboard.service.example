[Unit]
Description=Trading Bot Dashboard (Next.js)
After=network-online.target polybot-cloud-sync.service
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/trading-dashboard
Environment=NODE_ENV=production
Environment=PORT=3100
Environment=HOSTNAME=0.0.0.0
EnvironmentFile=/root/trading-dashboard/.env.production
ExecStart=/usr/bin/npm run start -- --hostname 0.0.0.0 --port 3100
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
