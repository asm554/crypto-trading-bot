[Unit]
Description=Polybot Momentum (Der Zocker) — Paper Trading
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/crypto-trading-bot
ExecStart=/root/crypto-trading-bot/bot-env/bin/python3 -m polybot.main_momentum
Restart=always
RestartSec=30
Environment=PYTHONUNBUFFERED=1
Environment=MOM_BUDGET=100
Environment=MOM_INTERVAL_H=1
Environment=MOM_ENTRY_CHANGE_PCT=3.0
Environment=MOM_ENTRY_MAX_CHANGE_PCT=25.0
Environment=MOM_MIN_VOLUME_EUR=500000
Environment=MOM_POSITION_EUR=12
Environment=MOM_MAX_OPEN_POSITIONS=4
Environment=MOM_TRAILING_STOP_PCT=2.5
Environment=MOM_HARD_STOP_PCT=4.0
Environment=MOM_MAX_HOLD_H=48
Environment=MOM_COOLDOWN_H=6
Environment=MOM_PAPER_MODE=true

[Install]
WantedBy=multi-user.target
