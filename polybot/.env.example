# Schritt 1: Kopiere nach polybot/.env (nachdem .gitignore steht — siehe Projekt-Root).
# Polymarket CLOB: docs.polymarket.com → API Keys (Key + Secret + Passphrase).
PRIVATE_KEY=0xYourPrivateKeyHere
CLOB_API_KEY=YourApiKeyHere
CLOB_SECRET=YourApiSecretHere
CLOB_PASSPHRASE=YourApiPassphraseHere
TELEGRAM_TOKEN=YourTelegramBotToken
TELEGRAM_CHAT_ID=YourTelegramChatId
# Standard: Paper. Live zusätzlich mit: python3 bot.py --live --confirm --i-understand-risks
PAPER_MODE=true
# Optional: Wetter-API (siehe weather_api.py)
VISUAL_CROSSING_KEY=
# Optional: Alchemy Polygon HTTPS (für eigene Web3-Tools; py_clob_client nutzt host/key/creds)
POLYGON_RPC_URL=
# Cloud-Sync fürs Online-Dashboard (Project Settings -> API in Supabase).
# WICHTIG: hier den service_role-Key eintragen (schreibt), NICHT den anon-Key.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Wie oft gespiegelt wird (Sekunden).
CLOUD_SYNC_INTERVAL_SEC=30
# Required by Der Spaeher for Jupiter Tokens V2 discovery and route quotes.
JUPITER_API_KEY=
